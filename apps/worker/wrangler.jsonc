{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "mockos",
  "main": "./src/index.ts",
  "compatibility_date": "2026-07-21",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "send_metrics": false,
  "keep_vars": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "version_metadata": {
    "binding": "CF_VERSION_METADATA"
  },
  "vars": {
    "HOSTING_MODE": "path",
    "PATH_PREFIX": "/e",
    "BASE_DOMAIN": "id.mockos.live",
    "ENTRA_HOST": "login.id.mockos.live",
    "E2E_INTROSPECTION_ENABLED": "false",
    "OUTBOUND_BLOCKED_HOSTS": "mockos.workspaceagent.workers.dev,mockos-staging.workspaceagent.workers.dev,mockos-edge.workspaceagent.workers.dev,mockos-edge-staging.workspaceagent.workers.dev,mockos-control.workspaceagent.workers.dev,mockos-control-staging.workspaceagent.workers.dev,mockos.live,id.mockos.live",
    "PUBLIC_ORIGIN": "https://mockos.workspaceagent.workers.dev",
    "SENTRY_ENVIRONMENT": "production"
  },
  "secrets": {
    "required": ["API_KEY"]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ENVIRONMENTS",
        "class_name": "EnvironmentDurableObject"
      },
      {
        "name": "ENVIRONMENT_CATALOG",
        "class_name": "EnvironmentCatalogDurableObject"
      },
      {
        "name": "MOCKOS_MCP",
        "class_name": "MockosMcpAgent"
      }
    ]
  },
  "workflows": [
    {
      "name": "mockos-provisioning",
      "binding": "PROVISIONING_WORKFLOW",
      "class_name": "ProvisioningWorkflow"
    }
  ],
  "migrations": [
    {
      "tag": "v1-environment",
      "new_sqlite_classes": ["EnvironmentDurableObject"]
    },
    {
      "tag": "v2-mcp-control",
      "new_sqlite_classes": ["EnvironmentCatalogDurableObject", "MockosMcpAgent"]
    }
  ],
  "env": {
    "staging": {
      "name": "mockos-staging",
      "workers_dev": true,
      "observability": {
        "enabled": true,
        "head_sampling_rate": 1
      },
      "version_metadata": {
        "binding": "CF_VERSION_METADATA"
      },
      "vars": {
        "HOSTING_MODE": "path",
        "PATH_PREFIX": "/e",
        "BASE_DOMAIN": "id.mockos.live",
        "ENTRA_HOST": "login.id.mockos.live",
        "E2E_INTROSPECTION_ENABLED": "false",
        "OUTBOUND_BLOCKED_HOSTS": "mockos.workspaceagent.workers.dev,mockos-staging.workspaceagent.workers.dev,mockos-edge.workspaceagent.workers.dev,mockos-edge-staging.workspaceagent.workers.dev,mockos-control.workspaceagent.workers.dev,mockos-control-staging.workspaceagent.workers.dev,mockos.live,id.mockos.live",
        "PUBLIC_ORIGIN": "https://mockos-staging.workspaceagent.workers.dev",
        "SENTRY_ENVIRONMENT": "staging"
      },
      "secrets": {
        "required": ["API_KEY"]
      },
      "durable_objects": {
        "bindings": [
          {
            "name": "ENVIRONMENTS",
            "class_name": "EnvironmentDurableObject"
          },
          {
            "name": "ENVIRONMENT_CATALOG",
            "class_name": "EnvironmentCatalogDurableObject"
          },
          {
            "name": "MOCKOS_MCP",
            "class_name": "MockosMcpAgent"
          }
        ]
      },
      "workflows": [
        {
          "name": "mockos-provisioning-staging",
          "binding": "PROVISIONING_WORKFLOW",
          "class_name": "ProvisioningWorkflow"
        }
      ]
    }
  }
}
