{
  "name": "@mockos/cli",
  "version": "0.1.0",
  "description": "Command-line client for mockOS environments, scenarios, tokens, logs, and assertions.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Jalil Laaraichi",
  "homepage": "https://github.com/reachjalil/mockos#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reachjalil/mockos.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/reachjalil/mockos/issues"
  },
  "keywords": [
    "cli",
    "entra-id",
    "identity",
    "mock",
    "oauth2",
    "oidc",
    "okta",
    "scim",
    "testing"
  ],
  "sideEffects": false,
  "bin": {
    "mockos": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/bin.js', 0o755)\"",
    "prepublishOnly": "pnpm build && pnpm test",
    "test": "vitest run",
    "types": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
