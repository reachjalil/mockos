{
  "name": "m6-scim-strict-missing-schemas",
  "description": "PATCH remains strict by default when the PatchOp schemas field is absent.",
  "provider": "entra",
  "resourceType": "User",
  "request": {
    "path": "/scim/v2/Users/usr_edge",
    "body": {
      "Operations": [
        { "op": "replace", "path": "displayName", "value": "Must not persist" }
      ]
    }
  },
  "expected": {
    "status": 400,
    "bodyContains": { "status": "400", "scimType": "invalidValue" },
    "stored": {
      "displayName": "Before edge case",
      "resourceVersion": 1,
      "deleted": false
    }
  }
}
