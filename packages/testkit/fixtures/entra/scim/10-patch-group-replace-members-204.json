{
  "name": "Microsoft Entra Group PATCH replaces members",
  "description": "The Entra group dialect replaces the membership array and returns 204 without a response body.",
  "provider": "entra",
  "area": "scim",
  "request": {
    "method": "PATCH",
    "path": "/scim/v2/Groups/grp_engineering",
    "headers": {
      "authorization": "Bearer fixture-scim-token",
      "content-type": "application/scim+json"
    },
    "body": {
      "schemas": ["urn:ietf:params:scim:api:messages:2.0:PatchOp"],
      "Operations": [
        {
          "op": "Replace",
          "path": "members",
          "value": [
            {
              "value": "usr_grace"
            }
          ]
        }
      ]
    }
  },
  "expected": {
    "status": 204
  },
  "provenance": "official-docs",
  "sourceUrl": "https://learn.microsoft.com/en-us/entra/identity/app-provisioning/use-scim-to-provision-users-and-groups",
  "lastVerified": "2026-07-22",
  "status": "implemented"
}
