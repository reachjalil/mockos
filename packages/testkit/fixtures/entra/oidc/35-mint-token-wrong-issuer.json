{
  "name": "Deterministic wrong-issuer token",
  "description": "The token fixture replaces iss with the fixed non-routable wrong-issuer.mockos.invalid origin.",
  "provider": "entra",
  "area": "oidc",
  "request": {
    "method": "POST",
    "path": "/mcp",
    "headers": {
      "accept": "application/json, text/event-stream",
      "authorization": "Bearer {{apiKey}}",
      "content-type": "application/json",
      "mcp-protocol-version": "2025-11-25",
      "mcp-session-id": "{{sessionId}}"
    },
    "body": {
      "jsonrpc": "2.0",
      "id": 35,
      "method": "tools/call",
      "params": {
        "name": "mint_token",
        "arguments": {
          "environmentId": "fixture-tokens-01",
          "clientId": "fixture-token-client",
          "subject": "fixture-user@example.test",
          "broken": "wrong_issuer"
        }
      }
    }
  },
  "expected": {
    "status": 200,
    "bodyContains": {
      "result": { "structuredContent": { "data": { "broken": "wrong_issuer" } } }
    }
  },
  "provenance": "official-docs",
  "sourceUrl": "https://learn.microsoft.com/en-us/entra/identity-platform/access-tokens",
  "lastVerified": "2026-07-22",
  "status": "implemented",
  "notes": "The M6 Worker fixture executor supplies the authenticated MCP session and configured client/subject; the replacement issuer is fixed by the engine and cannot initiate an outbound request."
}
