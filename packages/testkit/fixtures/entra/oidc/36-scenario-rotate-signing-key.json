{
  "name": "Rotate signing key before token signing",
  "description": "A one-shot internal token scenario promotes the pre-published next key while retaining the previous key for verification overlap.",
  "provider": "entra",
  "area": "oidc",
  "request": {
    "method": "POST",
    "path": "/mcp",
    "headers": {
      "accept": "application/json, text/event-stream",
      "authorization": "Bearer {{apiKey}}",
      "content-type": "application/json",
      "mcp-protocol-version": "2025-11-25",
      "mcp-session-id": "{{sessionId}}"
    },
    "body": {
      "jsonrpc": "2.0",
      "id": 36,
      "method": "tools/call",
      "params": {
        "name": "set_scenario",
        "arguments": {
          "environmentId": "fixture-tokens-01",
          "id": "rotate-once",
          "injectionPoint": "token.before_sign",
          "action": { "type": "rotate_signing_key" },
          "remaining": 1
        }
      }
    }
  },
  "expected": {
    "status": 200,
    "bodyContains": {
      "result": {
        "structuredContent": { "data": { "action": { "type": "rotate_signing_key" } } }
      }
    }
  },
  "provenance": "official-docs",
  "sourceUrl": "https://learn.microsoft.com/en-us/entra/identity-platform/signing-key-rollover",
  "lastVerified": "2026-07-22",
  "status": "implemented",
  "notes": "The M6 Worker fixture executor supplies the authenticated MCP session and configured environment; focused tests consume the one-shot scenario and verify both key generations by kid."
}
