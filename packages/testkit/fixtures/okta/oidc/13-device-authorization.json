{
  "name": "Okta device authorization response",
  "description": "The device endpoint returns device and user codes, activation URIs, expiry, and polling interval.",
  "provider": "okta",
  "area": "oidc",
  "request": {
    "method": "POST",
    "path": "/e/acme/oauth2/default/v1/device/authorize",
    "form": { "client_id": "0oaMockClient", "scope": "openid profile offline_access" }
  },
  "expected": {
    "status": 200,
    "bodyContains": {
      "expires_in": 600,
      "interval": 5,
      "verification_uri": "https://id.mockos.test/e/acme/activate"
    }
  },
  "provenance": "official-docs",
  "sourceUrl": "https://developer.okta.com/docs/guides/device-authorization-grant/main/",
  "lastVerified": "2026-07-22",
  "status": "documented",
  "notes": "Core returns camel-case fields; the edge adapter owns OAuth JSON casing."
}
