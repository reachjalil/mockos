{
  "name": "Okta approved device token response",
  "description": "After activation, a compliant poll returns access and ID tokens and an offline refresh token.",
  "provider": "okta",
  "area": "oidc",
  "request": {
    "method": "POST",
    "path": "/e/acme/oauth2/default/v1/token",
    "form": {
      "grant_type": "urn:ietf:params:oauth:grant-type:device_code",
      "device_code": "fixture-approved-device-code",
      "client_id": "0oaMockClient"
    }
  },
  "expected": {
    "status": 200,
    "bodyContains": {
      "token_type": "Bearer",
      "expires_in": 3600,
      "scope": "openid profile offline_access"
    }
  },
  "provenance": "official-docs",
  "sourceUrl": "https://developer.okta.com/docs/guides/device-authorization-grant/main/",
  "lastVerified": "2026-07-22",
