{
  "name": "okta-authn-invalid-credentials",
  "description": "Unknown users and wrong passwords receive the same generic authentication failure without account-state disclosure.",
  "provider": "okta",
  "area": "authn",
  "request": {
    "method": "POST",
    "path": "/api/v1/authn",
    "headers": { "content-type": "application/json" },
    "body": {
      "username": "mfa.authn@example.test",
      "password": "IncorrectSyntheticPassword"
    }
  },
  "expected": {
    "status": 401,
    "headers": { "cache-control": "no-store" },
    "bodyContains": {
      "errorCode": "E0000004",
      "errorSummary": "Authentication failed",
      "errorLink": "E0000004",
      "errorCauses": []
    }
  },
  "provenance": "official-docs",
  "sourceUrl": "https://developer.okta.com/docs/reference/api/authn/#response-example-for-primary-authentication-with-a-public-application-invalid-credentials",
  "lastVerified": "2026-07-22",
  "status": "implemented",
  "notes": "The executable corpus runs this wrong-password case against a user whose valid credentials would otherwise reveal MFA_REQUIRED."
}
