{
  "name": "okta-authn-password-expired",
  "description": "A user with a verified expired password enters PASSWORD_EXPIRED when MFA is not required.",
  "provider": "okta",
  "area": "authn",
  "request": {
    "method": "POST",
    "path": "/api/v1/authn",
    "headers": { "content-type": "application/json" },
    "body": {
      "username": "expired.authn@example.test",
      "password": "SyntheticPassw0rd!"
    }
  },
  "expected": {
    "status": 200,
    "headers": { "cache-control": "no-store" },
    "bodyContains": {
      "status": "PASSWORD_EXPIRED",
      "_embedded": {
        "user": {
          "profile": { "login": "expired.authn@example.test" }
        },
        "policy": {
          "complexity": { "minLength": 8 }
        }
      },
      "_links": {
        "next": { "name": "changePassword" }
      }
    }
  },
  "provenance": "official-docs",
  "sourceUrl": "https://developer.okta.com/docs/reference/api/authn/#response-example-for-primary-authentication-with-public-application-and-an-expired-password",
  "lastVerified": "2026-07-22",
  "status": "implemented",
  "notes": "MFA_REQUIRED takes precedence when the same synthetic user also has mfaState=required."
}
