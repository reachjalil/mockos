{
  "name": "Okta get-before-create finds User by userName",
  "description": "Okta filters by userName before deciding whether a downstream User already exists.",
  "provider": "okta",
  "area": "scim",
  "request": {
    "method": "GET",
    "path": "/scim/v2/Users",
    "headers": {
      "authorization": "Bearer fixture-scim-token"
    },
    "query": {
      "filter": "userName eq \"ada@example.test\""
    }
  },
  "expected": {
