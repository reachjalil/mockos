{
  "name": "Okta Group PATCH replaces filtered member",
  "description": "The Okta dialect replaces the member selected by a members valuePath with the static Grace User.",
  "provider": "okta",
  "area": "scim",
  "request": {
    "method": "PATCH",
    "path": "/scim/v2/Groups/grp_engineering",
    "headers": {
      "authorization": "Bearer fixture-scim-token",
      "content-type": "application/scim+json"
    },
    "body": {
      "schemas": ["urn:ietf:params:scim:api:messages:2.0:PatchOp"],
      "Operations": [
        {
          "op": "replace",
          "path": "members[value eq \"usr_ada\"]",
          "value": {
            "value": "usr_grace"
          }
        }
      ]
    }
  },
  "expected": {
    "status": 200,
    "headers": {
      "etag": "W/\"2\""
    },
    "bodyContains": {
      "id": "grp_engineering",
      "meta": {
        "version": "W/\"2\""
      }
    }
  },
  "provenance": "official-docs",
  "sourceUrl": "https://developer.okta.com/docs/api/openapi/okta-scim/guides/scim-20",
  "lastVerified": "2026-07-22",
  "status": "implemented"
}
