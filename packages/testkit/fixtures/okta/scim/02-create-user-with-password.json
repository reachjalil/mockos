{
  "name": "Okta creates User with generated password",
  "description": "Okta can include a password on create; the response asserts only non-sensitive stable fields and never the password.",
  "provider": "okta",
  "area": "scim",
  "request": {
    "method": "POST",
    "path": "/scim/v2/Users",
    "headers": {
      "authorization": "Bearer fixture-scim-token",
      "content-type": "application/scim+json"
    },
    "body": {
      "schemas": ["urn:ietf:params:scim:schemas:core:2.0:User"],
      "userName": "okta.new@example.test",
      "displayName": "Okta New User",
      "active": true,
      "password": "fixture-generated-password",
      "name": {
        "givenName": "Okta",
        "familyName": "User"
      }
    }
  },
  "expected": {
    "status": 201,
    "headers": {
      "etag": "W/\"1\""
    },
    "bodyContains": {
      "userName": "okta.new@example.test",
      "displayName": "Okta New User",
      "active": true,
      "meta": {
        "version": "W/\"1\""
      }
    }
  },
  "provenance": "official-docs",
  "sourceUrl": "https://developer.okta.com/docs/api/openapi/okta-scim/guides/scim-20",
  "lastVerified": "2026-07-22",
  "status": "implemented",
  "notes": "The generated id, Location, and sensitive password are intentionally absent from expected body matching."
}
