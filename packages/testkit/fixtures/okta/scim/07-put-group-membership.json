{
  "name": "Okta PUT replaces Group membership",
  "description": "A custom Okta integration can replace the full Group membership set with static User ids.",
  "provider": "okta",
  "area": "scim",
  "request": {
    "method": "PUT",
    "path": "/scim/v2/Groups/grp_engineering",
    "headers": {
      "authorization": "Bearer fixture-scim-token",
      "content-type": "application/scim+json"
    },
    "body": {
      "schemas": ["urn:ietf:params:scim:schemas:core:2.0:Group"],
      "id": "grp_engineering",
      "displayName": "Engineering",
      "members": [
        {
          "value": "usr_grace"
        }
      ]
    }
  },
  "expected": {
    "status": 200,
    "headers": {
      "etag": "W/\"2\""
    },
    "bodyContains": {
      "id": "grp_engineering",
      "meta": {
        "version": "W/\"2\""
      }
    }
  },
  "provenance": "official-docs",
  "sourceUrl": "https://developer.okta.com/docs/api/openapi/okta-scim/guides/scim-20",
  "lastVerified": "2026-07-22",
  "status": "implemented"
}
