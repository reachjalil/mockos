{
  "name": "RFC 7644 multi-valued attribute valuePath",
  "description": "A valuePath selects seeded Users whose work email is in the example.test domain.",
  "provider": "okta",
  "area": "scim",
  "request": {
    "method": "GET",
    "path": "/scim/v2/Users",
    "headers": {
      "authorization": "Bearer fixture-scim-token"
    },
    "query": {
      "filter": "emails[type eq \"work\" and value co \"@example.test\"]"
    }
  },
  "expected": {
    "status": 200,
    "bodyContains": {
      "schemas": ["urn:ietf:params:scim:api:messages:2.0:ListResponse"],
      "totalResults": 2,
      "startIndex": 1,
      "itemsPerPage": 2
    }
  },
  "provenance": "rfc",
  "sourceUrl": "https://datatracker.ietf.org/doc/html/rfc7644#section-3.4.2.2",
  "lastVerified": "2026-07-22",
  "status": "implemented"
}
