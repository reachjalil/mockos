{
  "name": "RFC 7644 reject User id mutation",
  "description": "PUT cannot change the service-provider-issued User id.",
  "provider": "okta",
  "area": "scim",
  "request": {
    "method": "PUT",
    "path": "/scim/v2/Users/usr_ada",
    "headers": {
      "authorization": "Bearer fixture-scim-token",
      "content-type": "application/scim+json"
    },
    "body": {
      "schemas": ["urn:ietf:params:scim:schemas:core:2.0:User"],
      "id": "usr_grace",
      "userName": "ada@example.test",
      "displayName": "Ada Lovelace",
      "active": true
    }
  },
  "expected": {
    "status": 400,
    "bodyContains": {
      "schemas": ["urn:ietf:params:scim:api:messages:2.0:Error"],
      "status": "400",
      "scimType": "mutability"
    }
  },
  "provenance": "rfc",
  "sourceUrl": "https://datatracker.ietf.org/doc/html/rfc7644#section-3.12",
  "lastVerified": "2026-07-22",
  "status": "implemented"
}
