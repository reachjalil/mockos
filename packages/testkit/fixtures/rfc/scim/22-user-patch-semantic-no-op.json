{
  "name": "RFC 7644 User PATCH semantic no-op preserves ETag",
  "description": "Replacing active with its existing value succeeds without changing metadata or the weak ETag.",
  "provider": "okta",
  "area": "scim",
  "request": {
    "method": "PATCH",
    "path": "/scim/v2/Users/usr_ada",
    "headers": {
      "authorization": "Bearer fixture-scim-token",
      "content-type": "application/scim+json",
      "if-match": "W/\"1\""
    },
    "body": {
      "schemas": ["urn:ietf:params:scim:api:messages:2.0:PatchOp"],
      "Operations": [
        {
          "op": "replace",
          "path": "active",
          "value": true
        }
      ]
    }
  },
  "expected": {
    "status": 200,
    "headers": {
      "etag": "W/\"1\""
    },
    "bodyContains": {
      "id": "usr_ada",
      "active": true,
      "meta": {
        "version": "W/\"1\""
      }
    }
  },
  "provenance": "rfc",
  "sourceUrl": "https://datatracker.ietf.org/doc/html/rfc7644#section-3.14",
  "lastVerified": "2026-07-22",
  "status": "implemented"
}
