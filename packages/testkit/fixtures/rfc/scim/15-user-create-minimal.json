{
  "name": "RFC 7644 create minimal User",
  "description": "Creating a unique minimal User returns 201 and a version-one representation without asserting its generated id.",
  "provider": "okta",
  "area": "scim",
  "request": {
    "method": "POST",
    "path": "/scim/v2/Users",
    "headers": {
      "authorization": "Bearer fixture-scim-token",
      "content-type": "application/scim+json"
    },
    "body": {
      "schemas": ["urn:ietf:params:scim:schemas:core:2.0:User"],
      "userName": "alan@example.test",
      "displayName": "Alan Turing",
      "active": true
    }
  },
  "expected": {
    "status": 201,
    "headers": {
      "etag": "W/\"1\""
    },
    "bodyContains": {
      "schemas": ["urn:ietf:params:scim:schemas:core:2.0:User"],
      "userName": "alan@example.test",
      "displayName": "Alan Turing",
      "active": true,
      "meta": {
        "resourceType": "User",
        "version": "W/\"1\""
      }
    }
  },
  "provenance": "rfc",
  "sourceUrl": "https://datatracker.ietf.org/doc/html/rfc7644#section-3.3",
