{
  "name": "RFC 7644 reject duplicate User userName",
  "description": "Creating a User whose userName matches a seed fails with a uniqueness conflict.",
  "provider": "okta",
  "area": "scim",
  "request": {
    "method": "POST",
    "path": "/scim/v2/Users",
    "headers": {
      "authorization": "Bearer fixture-scim-token",
      "content-type": "application/scim+json"
    },
    "body": {
      "schemas": ["urn:ietf:params:scim:schemas:core:2.0:User"],
      "userName": "ada@example.test",
      "displayName": "Duplicate Ada",
      "active": true
    }
  },
  "expected": {
    "status": 409,
    "bodyContains": {
      "schemas": ["urn:ietf:params:scim:api:messages:2.0:Error"],
      "status": "409",
      "scimType": "uniqueness"
    }
  },
  "provenance": "rfc",
  "sourceUrl": "https://datatracker.ietf.org/doc/html/rfc7644#section-3.3",
  "lastVerified": "2026-07-22",
  "status": "implemented"
}
