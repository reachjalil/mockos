{
  "name": "RFC 7644 replace Group membership with PUT",
  "description": "PUT replaces the seeded membership set with the static Grace user.",
  "provider": "okta",
  "area": "scim",
  "request": {
    "method": "PUT",
    "path": "/scim/v2/Groups/grp_engineering",
    "headers": {
      "authorization": "Bearer fixture-scim-token",
      "content-type": "application/scim+json"
    },
    "body": {
      "schemas": ["urn:ietf:params:scim:schemas:core:2.0:Group"],
      "id": "grp_engineering",
      "displayName": "Engineering",
      "members": [
        {
          "value": "usr_grace"
        }
      ]
    }
  },
  "expected": {
    "status": 200,
    "headers": {
      "etag": "W/\"2\""
    },
    "bodyContains": {
      "id": "grp_engineering",
      "displayName": "Engineering",
      "meta": {
        "version": "W/\"2\""
      }
    }
  },
  "provenance": "rfc",
  "sourceUrl": "https://datatracker.ietf.org/doc/html/rfc7644#section-3.5.1",
  "lastVerified": "2026-07-22",
  "status": "implemented"
}
