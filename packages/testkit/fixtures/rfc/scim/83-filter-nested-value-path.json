{
  "name": "RFC 7644 reject nested filter valuePath",
  "description": "The bounded M3 parser rejects nested multi-valued valuePath expressions.",
  "provider": "okta",
  "area": "scim",
  "request": {
    "method": "GET",
    "path": "/scim/v2/Users",
    "headers": {
      "authorization": "Bearer fixture-scim-token"
    },
    "query": {
      "filter": "emails[type[display eq \"work\"] eq \"work\"]"
    }
  },
  "expected": {
    "status": 400,
    "bodyContains": {
      "schemas": ["urn:ietf:params:scim:api:messages:2.0:Error"],
      "status": "400",
      "scimType": "invalidFilter"
    }
  },
  "provenance": "rfc",
  "sourceUrl": "https://datatracker.ietf.org/doc/html/rfc7644#section-3.4.2.2",
  "lastVerified": "2026-07-22",
  "status": "implemented"
}
