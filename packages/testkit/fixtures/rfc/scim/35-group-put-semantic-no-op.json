{
  "name": "RFC 7644 Group PUT semantic no-op preserves ETag",
  "description": "A complete replacement equal to the seeded Group succeeds without advancing its weak ETag.",
  "provider": "okta",
  "area": "scim",
  "request": {
    "method": "PUT",
    "path": "/scim/v2/Groups/grp_engineering",
    "headers": {
      "authorization": "Bearer fixture-scim-token",
      "content-type": "application/scim+json",
      "if-match": "W/\"1\""
    },
    "body": {
      "schemas": ["urn:ietf:params:scim:schemas:core:2.0:Group"],
      "id": "grp_engineering",
      "displayName": "Engineering",
      "members": [
        {
          "value": "usr_ada"
        }
      ]
    }
  },
  "expected": {
    "status": 200,
    "headers": {
      "etag": "W/\"1\""
    },
    "bodyContains": {
      "id": "grp_engineering",
      "displayName": "Engineering",
      "meta": {
        "version": "W/\"1\""
      }
    }
  },
  "provenance": "rfc",
  "sourceUrl": "https://datatracker.ietf.org/doc/html/rfc7644#section-3.14",
  "lastVerified": "2026-07-22",
  "status": "implemented"
}
