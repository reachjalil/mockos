{
  "name": "RFC 7643 create User with enterprise extension",
  "description": "A User create accepts and returns the standard enterprise extension.",
  "provider": "okta",
  "area": "scim",
  "request": {
    "method": "POST",
    "path": "/scim/v2/Users",
    "headers": {
      "authorization": "Bearer fixture-scim-token",
      "content-type": "application/scim+json"
    },
    "body": {
      "schemas": [
        "urn:ietf:params:scim:schemas:core:2.0:User",
        "urn:ietf:params:scim:schemas:extension:enterprise:2.0:User"
      ],
      "userName": "katherine@example.test",
      "displayName": "Katherine Johnson",
      "active": true,
      "name": {
        "givenName": "Katherine",
        "familyName": "Johnson"
      },
      "emails": [
        {
          "value": "katherine@example.test",
          "type": "work",
          "primary": true
        }
      ],
      "urn:ietf:params:scim:schemas:extension:enterprise:2.0:User": {
        "department": "Flight Research",
        "employeeNumber": "NASA-001",
        "manager": {
          "value": "usr_grace"
        }
      }
    }
  },
  "expected": {
    "status": 201,
    "headers": {
      "etag": "W/\"1\""
    },
    "bodyContains": {
      "userName": "katherine@example.test",
      "urn:ietf:params:scim:schemas:extension:enterprise:2.0:User": {
        "department": "Flight Research",
        "employeeNumber": "NASA-001",
        "manager": {
          "value": "usr_grace"
        }
      },
      "meta": {
        "resourceType": "User",
        "version": "W/\"1\""
      }
    }
  },
  "provenance": "rfc",
  "sourceUrl": "https://datatracker.ietf.org/doc/html/rfc7643#section-4.3",
  "lastVerified": "2026-07-22",
  "status": "implemented",
  "notes": "The generated resource id and Location header are deliberately omitted from exact matching."
}
